{
  "name": "share-proxy",
  "version": "0.0.1",
  "private": true,
  "description": "Create public links for media hosted across different platforms",
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:admin": "pnpm --filter @share-proxy/admin-api --filter admin-web --parallel run dev",
    "build": "pnpm -r run build",
    "start": "pnpm -r run start",
    "lint": "pnpm -r --if-present run lint",
    "test": "pnpm -r --if-present run test && playwright test",
    "test:ci": "pnpm -r --filter=!share-proxy --if-present run test",
    "test:unit": "pnpm --filter @share-proxy/adapters test:unit",
    "test:integration": "pnpm --filter @share-proxy/admin-api test:integration",
    "test:e2e": "playwright test",
    "test:adapters": "pnpm --filter @share-proxy/adapters test",
    "test:adapters:unit": "pnpm --filter @share-proxy/adapters test:unit",
    "test:admin-api": "pnpm --filter @share-proxy/admin-api test",
    "test:admin-api:integration": "pnpm --filter @share-proxy/admin-api test:integration",
    "test:admin-web": "pnpm --filter admin-web test",
    "test:admin-web:unit": "pnpm --filter admin-web test:unit",
    "test:admin-web:e2e": "pnpm --filter admin-web test:e2e"
  },
  "author": "Sergey Minakov",
  "license": "AGPL-3.0",
  "packageManager": "pnpm@10.30.1",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "playwright": "^1.58.2",
    "tslib": "^2.8.1"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.0"
  }
}
