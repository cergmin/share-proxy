# Type of database to use: 'pglite' (embedded, no separate server needed) or 'postgres' (standard PostgreSQL)
DB_TYPE=pglite

# Connection string for PostgreSQL (Only used if DB_TYPE=postgres)
# Format: postgresql://user:password@host:port/database
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/share_proxy

# Directory to store PGLite database files (Only used if DB_TYPE=pglite)
# Set to 'memory://' to use an in-memory database that clears on restart
PGLITE_DIR=./storage/db

# Secret key used for session signing and BetterAuth operations
# Must be a long, random string in production
SECRET=changeme

# The public facing URL of the Admin API for authentication redirects
ADMIN_API_ORIGIN=http://localhost:3000

# Admin Web Frontend URL
ADMIN_FRONTEND_ORIGIN=http://localhost:5173

# Port for the Admin API to listen on
ADMIN_API_PORT=3000

# Port for the Proxy Streaming Service to listen on
PROXY_PORT=3001
