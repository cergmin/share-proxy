# PostgreSQL connection string used by admin-api and proxy.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/share_proxy

# Host path where the local postgres container stores its files.
# `pnpm dev` automatically starts `docker compose up -d --wait postgres`
# and bind-mounts this directory into the container.
POSTGRES_DATA_DIR=./storage/db

# Secret key used for session signing and BetterAuth operations
# Must be a long, random string in production
SECRET=changeme

# The public facing URL of the Admin API for authentication redirects
ADMIN_API_ORIGIN=http://localhost:3000

# Admin Web Frontend URL
ADMIN_FRONTEND_ORIGIN=http://localhost:5173

# Port for the Admin API to listen on
ADMIN_API_PORT=3000

# Port for the Proxy Streaming Service to listen on
PROXY_PORT=3001

# Public URL used to build viewer links shown in the admin panel
PROXY_ORIGIN=http://localhost:3001
