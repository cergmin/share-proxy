{
    "name": "@share-proxy/proxy",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "pnpm --filter @share-proxy/video-player build && tsc",
        "start": "node dist/index.js",
        "test": "node ../../scripts/ensure-postgres.mjs && pnpm --filter @share-proxy/video-player build && vitest run"
    },
    "dependencies": {
        "@share-proxy/adapters": "workspace:*",
        "@share-proxy/core": "workspace:*",
        "@share-proxy/db": "workspace:*",
        "@share-proxy/video-player": "workspace:*",
        "dotenv": "^17.3.1",
        "drizzle-orm": "^0.45.1",
        "fastify": "^5.8.2"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^4.1.0"
    }
}
